# MemU MCP Server Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Provider Selection
# ============================================================================
# Choose your LLM provider: ollama | openrouter | deepinfra | fireworks | lmstudio | openai
MEMU_PROVIDER=ollama

# ============================================================================
# Ollama Configuration (Local)
# ============================================================================
OLLAMA_BASE_URL=http://localhost:11434/v1
# Use http://host.docker.internal:11434/v1 when running in Docker
OLLAMA_MODEL=llama3
OLLAMA_API_KEY=ollama

# ============================================================================
# OpenRouter Configuration
# ============================================================================
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ============================================================================
# DeepInfra Configuration
# ============================================================================
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
DEEPINFRA_API_KEY=your_deepinfra_api_key_here
DEEPINFRA_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# ============================================================================
# Fireworks AI Configuration
# ============================================================================
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

# ============================================================================
# LMStudio Configuration (Local)
# ============================================================================
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# Use http://host.docker.internal:1234/v1 when running in Docker
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=local-model

# ============================================================================
# OpenAI Configuration
# ============================================================================
OPENAI_API_KEY=your_openai_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_CHAT_MODEL=gpt-4o-mini
LLM_EMBED_MODEL=text-embedding-3-small

# ============================================================================
# Database Configuration
# ============================================================================
DB_PROVIDER=inmemory  # or "postgres"
# DB_DSN=postgresql://user:password@localhost:5432/memu

# ============================================================================
# Retrieval Configuration
# ============================================================================
RETRIEVE_METHOD=rag  # "rag" or "llm"

# ============================================================================
# Optional: Configuration File Path
# ============================================================================
# MEMU_CONFIG_PATH=/path/to/config.yaml
