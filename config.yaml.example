# MemU MCP Server Configuration Example
# Copy this file to config.yaml and customize for your provider

# Provider selection: ollama | openrouter | deepinfra | fireworks | lmstudio | openai | vllm | custom
provider: "ollama"

# LLM Profiles Configuration
# You can define multiple profiles for different LLM providers
llm_profiles:
  # Default profile - used for most operations
  default:
    base_url: "http://host.docker.internal:11434/v1"  # Use host.docker.internal in Docker
    api_key: "ollama"  # Not required for Ollama but needed for client init
    chat_model: "llama3"
    embed_model: "llama3"
    client_backend: "sdk"  # Use 'sdk' for OpenAI-compatible endpoints

  # Alternative: OpenRouter configuration
  # default:
  #   base_url: "https://openrouter.ai/api/v1"
  #   api_key: "${OPENROUTER_API_KEY}"  # Will be replaced from environment
  #   chat_model: "anthropic/claude-3.5-sonnet"
  #   client_backend: "sdk"

  # Alternative: DeepInfra configuration
  # default:
  #   base_url: "https://api.deepinfra.com/v1/openai"
  #   api_key: "${DEEPINFRA_API_KEY}"
  #   chat_model: "meta-llama/Meta-Llama-3.1-70B-Instruct"
  #   client_backend: "sdk"

  # Alternative: Fireworks AI configuration
  # default:
  #   base_url: "https://api.fireworks.ai/inference/v1"
  #   api_key: "${FIREWORKS_API_KEY}"
  #   chat_model: "accounts/fireworks/models/llama-v3p1-70b-instruct"
  #   client_backend: "sdk"

  # Alternative: LMStudio configuration
  # default:
  #   base_url: "http://host.docker.internal:1234/v1"
  #   api_key: "lm-studio"
  #   chat_model: "local-model"  # Use the model name from LMStudio
  #   client_backend: "sdk"

  # Alternative: OpenAI configuration
  # default:
  #   base_url: "https://api.openai.com/v1"
  #   api_key: "${OPENAI_API_KEY}"
  #   chat_model: "gpt-4o-mini"
  #   embed_model: "text-embedding-3-small"
  #   client_backend: "sdk"

  # Separate embedding profile (optional)
  # embedding:
  #   base_url: "https://api.voyageai.com/v1"
  #   api_key: "${VOYAGE_API_KEY}"
  #   embed_model: "voyage-3.5-lite"
  #   client_backend: "sdk"

# ============================================================================
# vLLM Self-Hosted Configuration (fully local, best quality, quantized Qwen)
# ============================================================================
# Uncomment and set provider: "vllm" to use this configuration.
#
# This setup runs three separate vLLM instances on different ports:
#   - Port 8000: Qwen2.5-14B-Instruct-AWQ  (chat / reasoning)
#   - Port 8001: Qwen3-Embedding            (dense text embeddings)
#   - Port 8002: Qwen3-Reranker             (cross-encoder reranking)
#
# Launch commands (one terminal per model):
#
#   # Chat model (AWQ 4-bit quantization)
#   vllm serve Qwen/Qwen2.5-14B-Instruct-AWQ \
#       --port 8000 --quantization awq --max-model-len 32768
#
#   # Embedding model
#   vllm serve Qwen/Qwen3-Embedding \
#       --port 8001 --task embed --max-model-len 8192
#
#   # Reranker model
#   vllm serve Qwen/Qwen3-Reranker \
#       --port 8002 --task score --max-model-len 8192
#
# For smaller GPU (e.g. 24 GB VRAM), use:
#   Chat:    Qwen/Qwen2.5-7B-Instruct-AWQ
#   Embed:   Qwen/Qwen3-Embedding-0.6B
#   Rerank:  Qwen/Qwen3-Reranker-0.6B
#
# provider: "vllm"
#
# llm_profiles:
#   default:
#     base_url: "http://localhost:8000/v1"
#     api_key: "EMPTY"
#     chat_model: "Qwen/Qwen2.5-14B-Instruct-AWQ"
#     client_backend: "sdk"
#   embedding:
#     base_url: "http://localhost:8001/v1"
#     api_key: "EMPTY"
#     embed_model: "Qwen/Qwen3-Embedding"
#     chat_model: "Qwen/Qwen3-Embedding"
#     client_backend: "sdk"
#
# retrieve_config:
#   method: "rag"
#   route_intention: true
#   sufficiency_check: true
#   reranker:
#     enabled: true
#     base_url: "http://localhost:8002/v1"
#     api_key: "EMPTY"
#     model: "Qwen/Qwen3-Reranker"
#     top_n: 5

# Database Configuration
database_config:
  metadata_store:
    provider: "inmemory"  # or "postgres"
    # dsn: "postgresql://user:pass@localhost:5432/memu"  # For postgres

# Retrieval Configuration
retrieve_config:
  method: "rag"  # "rag" for fast vector search, "llm" for deep semantic understanding
  route_intention: true
  sufficiency_check: true
  # reranker:
  #   enabled: false
  #   base_url: "http://localhost:8002/v1"
  #   api_key: "EMPTY"
  #   model: "Qwen/Qwen3-Reranker-0.6B"
  #   top_n: 5

# Memory Configuration (optional)
# memorize_config:
#   category_assign_threshold: 0.25
#   memory_types:
#     - "profile"
#     - "event"
#     - "knowledge"
#     - "behavior"
