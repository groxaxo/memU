# MemU MCP Server Configuration Example
# Copy this file to config.yaml and customize for your provider

# Provider selection: ollama | openrouter | deepinfra | fireworks | lmstudio | openai | custom
provider: "ollama"

# LLM Profiles Configuration
# You can define multiple profiles for different LLM providers
llm_profiles:
  # Default profile - used for most operations
  default:
    base_url: "http://host.docker.internal:11434/v1"  # Use host.docker.internal in Docker
    api_key: "ollama"  # Not required for Ollama but needed for client init
    chat_model: "llama3"
    embed_model: "llama3"
    client_backend: "sdk"  # Use 'sdk' for OpenAI-compatible endpoints

  # Alternative: OpenRouter configuration
  # default:
  #   base_url: "https://openrouter.ai/api/v1"
  #   api_key: "${OPENROUTER_API_KEY}"  # Will be replaced from environment
  #   chat_model: "anthropic/claude-3.5-sonnet"
  #   client_backend: "sdk"

  # Alternative: DeepInfra configuration
  # default:
  #   base_url: "https://api.deepinfra.com/v1/openai"
  #   api_key: "${DEEPINFRA_API_KEY}"
  #   chat_model: "meta-llama/Meta-Llama-3.1-70B-Instruct"
  #   client_backend: "sdk"

  # Alternative: Fireworks AI configuration
  # default:
  #   base_url: "https://api.fireworks.ai/inference/v1"
  #   api_key: "${FIREWORKS_API_KEY}"
  #   chat_model: "accounts/fireworks/models/llama-v3p1-70b-instruct"
  #   client_backend: "sdk"

  # Alternative: LMStudio configuration
  # default:
  #   base_url: "http://host.docker.internal:1234/v1"
  #   api_key: "lm-studio"
  #   chat_model: "local-model"  # Use the model name from LMStudio
  #   client_backend: "sdk"

  # Alternative: OpenAI configuration
  # default:
  #   base_url: "https://api.openai.com/v1"
  #   api_key: "${OPENAI_API_KEY}"
  #   chat_model: "gpt-4o-mini"
  #   embed_model: "text-embedding-3-small"
  #   client_backend: "sdk"

  # Separate embedding profile (optional)
  # embedding:
  #   base_url: "https://api.voyageai.com/v1"
  #   api_key: "${VOYAGE_API_KEY}"
  #   embed_model: "voyage-3.5-lite"
  #   client_backend: "sdk"

# Database Configuration
database_config:
  metadata_store:
    provider: "inmemory"  # or "postgres"
    # dsn: "postgresql://user:pass@localhost:5432/memu"  # For postgres

# Retrieval Configuration
retrieve_config:
  method: "rag"  # "rag" for fast vector search, "llm" for deep semantic understanding
  route_intention: true
  sufficiency_check: true

# Memory Configuration (optional)
# memorize_config:
#   category_assign_threshold: 0.25
#   memory_types:
#     - "profile"
#     - "event"
#     - "knowledge"
#     - "behavior"
